<idea-plugin>
    <id>katze.mill-template-plugin</id>
    <name>Mill Project Template</name>
    <vendor>Katze</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>
    <depends>org.intellij.scala</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <completion.contributor language="yaml" implementationClass="katze.intellijmill.YamlCompletionContributor"/>
        <psi.referenceContributor language="yaml" implementation="katze.intellijmill.YamlReferenceContributor"/>
    </extensions>
</idea-plugin>
